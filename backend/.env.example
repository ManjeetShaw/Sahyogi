PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/civicai

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# AI companion (server-side only, never exposed to the client)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# CORS
# Comma-separated list of allowed frontend origins (no trailing slashes)
CLIENT_ORIGIN=http://localhost:5173,https://sahyogi-tau.vercel.app
